<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Smart AgriGuard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border: 1px solid rgba(226, 232, 240, 0.8); }
    </style>
</head>
<body class="text-gray-800">

    <!-- Navbar -->
    <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <svg class="w-8 h-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                        <span class="font-bold text-xl text-gray-900 tracking-tight">Smart AgriGuard</span>
                    </div>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/dashboard" class="text-teal-600 font-medium px-3 py-2 rounded-md text-sm hover:bg-teal-50 transition-colors">Dashboard</a>
                    <a href="/analytics" class="text-gray-500 hover:text-teal-600 font-medium px-3 py-2 rounded-md text-sm transition-colors">Analytics</a>
                    <a href="/" class="ml-4 px-4 py-2 text-sm font-medium text-white bg-gray-800 hover:bg-gray-900 rounded-lg transition-colors">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-gray-900">Live Dashboard</h2>
            <div class="flex items-center gap-2">
                <span class="relative flex h-3 w-3">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                </span>
                <span class="text-sm font-medium text-emerald-600">System Active</span>
            </div>
        </div>

        <!-- 4 Large Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <!-- Temp -->
            <div class="glass-card rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-orange-100 rounded-full opacity-50"></div>
                <div class="flex items-center justify-between mb-4 relative z-10">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Temperature</h3>
                    <div class="p-2 bg-orange-50 rounded-lg text-orange-500">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                </div>
                <div class="flex items-baseline gap-2 relative z-10">
                    <span id="temp" class="text-4xl font-bold text-gray-900">--</span>
                    <span class="text-lg font-medium text-gray-500">°C</span>
                </div>
            </div>

            <!-- Humidity -->
            <div class="glass-card rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-blue-100 rounded-full opacity-50"></div>
                <div class="flex items-center justify-between mb-4 relative z-10">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Humidity</h3>
                    <div class="p-2 bg-blue-50 rounded-lg text-blue-500">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
                    </div>
                </div>
                <div class="flex items-baseline gap-2 relative z-10">
                    <span id="hum" class="text-4xl font-bold text-gray-900">--</span>
                    <span class="text-lg font-medium text-gray-500">%</span>
                </div>
            </div>

            <!-- Soil Moisture -->
            <div class="glass-card rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-100 rounded-full opacity-50"></div>
                <div class="flex items-center justify-between mb-4 relative z-10">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Soil Moisture</h3>
                    <div class="p-2 bg-amber-50 rounded-lg text-amber-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
                    </div>
                </div>
                <div class="flex items-baseline gap-2 relative z-10">
                    <span id="soil" class="text-4xl font-bold text-gray-900">--</span>
                    <span class="text-lg font-medium text-gray-500">%</span>
                </div>
            </div>

            <!-- Status -->
            <div class="glass-card rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden">
                <div class="flex items-center justify-between mb-4 relative z-10">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">System Status</h3>
                    <div id="status-icon" class="p-2 bg-gray-100 rounded-lg text-gray-500">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                </div>
                <div class="mt-2 relative z-10">
                    <span id="status" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                        Loading...
                    </span>
                </div>
            </div>
        </div>

        <!-- Predicted Values (Ngrok) -->
        <div class="mb-8 bg-gradient-to-r from-teal-500 to-emerald-600 rounded-2xl p-6 text-white shadow-lg relative overflow-hidden">
            <div class="absolute right-0 top-0 w-64 h-64 bg-white opacity-5 rounded-full -mr-20 -mt-20"></div>
            <h3 class="text-lg font-semibold mb-4 flex items-center gap-2 relative z-10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                AI Predictions (Ngrok API)
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 relative z-10">
                <div class="bg-white/10 backdrop-blur-md rounded-xl p-4 border border-white/20">
                    <div class="text-teal-100 text-sm mb-1">Predicted Temperature</div>
                    <div class="text-3xl font-bold"><span id="pred-temp">--</span> °C</div>
                </div>
                <div class="bg-white/10 backdrop-blur-md rounded-xl p-4 border border-white/20">
                    <div class="text-teal-100 text-sm mb-1">Predicted Humidity</div>
                    <div class="text-3xl font-bold"><span id="pred-hum">--</span> %</div>
                </div>
            </div>
            <p class="text-xs text-teal-100 mt-4 opacity-80">Data fetched from external ML model</p>
        </div>

        <!-- Latest Intrusions -->
        <div class="glass-card rounded-2xl shadow-sm overflow-hidden mb-8">
            <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-white/50">
                <h3 class="text-lg font-semibold text-gray-900">Latest Intrusion Alerts</h3>
                <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded-full font-medium">Critical</span>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50/50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Event</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody id="intrusion-table" class="bg-white/40 divide-y divide-gray-100">
                        <!-- Filled by JS -->
                    </tbody>
                </table>
                <div id="no-intrusions" class="text-center py-8 text-gray-500 hidden">
                    <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    No recent intrusions detected.
                </div>
            </div>
        </div>

    </main>

    <script>
        // Replace this with your actual ngrok URL when you have it
        const NGROK_API_URL = "https://your-ngrok-url.ngrok-free.app/predict";

        async function fetchPredictions() {
            try {
                // To avoid CORS issues if not configured on ngrok, we attempt to fetch
                const response = await fetch(NGROK_API_URL, {
                    headers: { 'ngrok-skip-browser-warning': 'true' }
                });
                if(response.ok) {
                    const data = await response.json();
                    document.getElementById('pred-temp').textContent = data.temperature || '--';
                    document.getElementById('pred-hum').textContent = data.humidity || '--';
                }
            } catch (error) {
                console.log("Could not fetch ngrok predictions, ensure the URL is correct and server is running.", error);
            }
        }

        async function fetchData() {
            try {
                const response = await fetch('/api/latest');
                const data = await response.json();

                if (data.latest) {
                    document.getElementById('temp').textContent = data.latest.temperature;
                    document.getElementById('hum').textContent = data.latest.humidity;
                    document.getElementById('soil').textContent = data.latest.soilMoisture;
                    
                    const statusEl = document.getElementById('status');
                    const statusIconEl = document.getElementById('status-icon');
                    const statusText = data.latest.status;
                    
                    statusEl.textContent = statusText;
                    
                    // Reset classes
                    statusEl.className = 'inline-flex items-center px-3 py-1 rounded-full text-sm font-medium';
                    statusIconEl.className = 'p-2 rounded-lg';

                    if (statusText === 'Safe') {
                        statusEl.classList.add('bg-green-100', 'text-green-800');
                        statusIconEl.classList.add('bg-green-50', 'text-green-500');
                        statusIconEl.innerHTML = '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
                    } else if (statusText === 'Intrusion Detected') {
                        statusEl.classList.add('bg-red-100', 'text-red-800');
                        statusIconEl.classList.add('bg-red-50', 'text-red-500');
                        statusIconEl.innerHTML = '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>';
                    } else {
                        statusEl.classList.add('bg-yellow-100', 'text-yellow-800');
                        statusIconEl.classList.add('bg-yellow-50', 'text-yellow-500');
                        statusIconEl.innerHTML = '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
                    }
                }

                // Intrusions Table
                const tbody = document.getElementById('intrusion-table');
                const noIntrusions = document.getElementById('no-intrusions');
                
                tbody.innerHTML = '';
                
                if (data.intrusions && data.intrusions.length > 0) {
                    noIntrusions.classList.add('hidden');
                    data.intrusions.forEach(item => {
                        const date = new Date(item.timestamp);
                        const row = `
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${date.toLocaleString()}</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center text-sm font-medium text-gray-900">
                                        <span class="w-2 h-2 bg-red-500 rounded-full mr-2 animate-pulse"></span>
                                        Motion Detected
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                                        Alert
                                    </span>
                                </td>
                            </tr>
                        `;
                        tbody.innerHTML += row;
                    });
                } else {
                    noIntrusions.classList.remove('hidden');
                }

            } catch (error) {
                console.error('Error fetching data:', error);
            }
        }

        // Initial fetch
        fetchData();
        fetchPredictions();

        // Refresh every 8 seconds
        setInterval(fetchData, 8000);
        setInterval(fetchPredictions, 8000);
    </script>
</body>
</html>
